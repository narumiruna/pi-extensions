{
	"name": "@narumitw/pi-goals",
	"version": "0.0.0",
	"description": "Experimental Pi extension for ordered goal arrays.",
	"type": "module",
	"license": "MIT",
	"private": false,
	"keywords": [
		"pi-package",
		"pi-extension",
		"pi",
		"goals",
		"queue",
		"automation"
	],
	"files": [
		"src",
		"README.md",
		"LICENSE"
	],
	"pi": {
		"extensions": [
			"./src/goals.ts"
		]
	},
	"scripts": {
		"check": "biome check . && npm run typecheck",
		"format": "biome check --write .",
		"test:runtime": "node ./test/goals-runtime-smoke.mjs",
		"typecheck": "tsc --noEmit"
	},
	"dependencies": {
		"typebox": "^1.3.3"
	},
	"devDependencies": {
		"@biomejs/biome": "2.5.2",
		"@earendil-works/pi-ai": "0.80.6",
		"@earendil-works/pi-coding-agent": "0.80.6",
		"typescript": "6.0.3"
	},
	"repository": {
		"type": "git",
		"url": "https://github.com/narumiruna/pi-extensions",
		"directory": "extensions/experimental/pi-goals"
	}
}
