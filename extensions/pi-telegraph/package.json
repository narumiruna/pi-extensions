{
	"name": "@narumitw/pi-telegraph",
	"version": "0.20.2",
	"description": "Pi extension for creating, reading, and editing Telegraph pages.",
	"type": "module",
	"license": "MIT",
	"private": false,
	"keywords": [
		"pi-package",
		"pi-extension",
		"pi",
		"telegraph",
		"telegra.ph",
		"publishing",
		"markdown"
	],
	"files": [
		"src",
		"README.md",
		"LICENSE"
	],
	"pi": {
		"extensions": [
			"./src/telegraph.ts"
		]
	},
	"scripts": {
		"check": "biome check . && npm run typecheck",
		"format": "biome check --write .",
		"typecheck": "tsc --noEmit"
	},
	"dependencies": {
		"marked": "^18.0.5",
		"typebox": "^1.3.3"
	},
	"devDependencies": {
		"@biomejs/biome": "2.5.3",
		"@earendil-works/pi-coding-agent": "0.80.10",
		"typescript": "7.0.2"
	},
	"repository": {
		"type": "git",
		"url": "https://github.com/narumiruna/pi-extensions",
		"directory": "extensions/pi-telegraph"
	}
}
