{
	"name": "@narumitw/pi-sidebar",
	"version": "0.1.14",
	"description": "Pi extension that adds an opencode-style right sidebar overlay to the interactive TUI.",
	"type": "module",
	"license": "MIT",
	"private": false,
	"keywords": [
		"pi-package",
		"pi-extension",
		"pi",
		"sidebar",
		"tui",
		"overlay"
	],
	"files": [
		"src",
		"README.md",
		"LICENSE"
	],
	"pi": {
		"extensions": [
			"./src/sidebar.ts"
		]
	},
	"scripts": {
		"check": "biome check . && npm run typecheck",
		"format": "biome check --write .",
		"typecheck": "tsc --noEmit"
	},
	"peerDependencies": {
		"@earendil-works/pi-coding-agent": "*",
		"@earendil-works/pi-tui": "*"
	},
	"devDependencies": {
		"@biomejs/biome": "2.4.14",
		"@earendil-works/pi-coding-agent": "0.74.0",
		"@earendil-works/pi-tui": "0.74.0",
		"@types/node": "25.6.0",
		"typescript": "6.0.3"
	},
	"repository": {
		"type": "git",
		"url": "https://github.com/narumiruna/pi-extensions",
		"directory": "extensions/pi-sidebar"
	}
}
